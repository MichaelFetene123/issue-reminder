generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id               String    @id @default(cuid())
  email            String    @unique
  password         String
  emailVerifid     Boolean   @default(false)
  emailToken       String    @default("")
  emailTokenExpiry DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  issues           Issue[]

  @@map("users")
}

model Issue {
  id          String         @id @default(cuid())
  title       String
  description String
  priority    priorityStatus
  status      IssueStatus
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  userId      String
  user        User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("issues")
}

// Enum to manage the status of the issue

enum IssueStatus {
  BACKLOG
  TODO
  IN_PROGRESS
  DONE
}

enum priorityStatus {
  LOW
  MEDIUM
  HIGH
}
